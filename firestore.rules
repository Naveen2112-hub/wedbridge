rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }

    match /vendors/{id} {
      allow read: if resource.data.status == "approved" || isOwner(resource.data.ownerUid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.ownerUid) || isAdmin();
      allow delete: if isAdmin();
    }
    match /vendorCategories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /vendorBookings/{id} {
      allow read: if isOwner(resource.data.userId) || (resource.data.vendorId != null && isVendorOwner(resource.data.vendorId)) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }
    match /vendorReviews/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }
    match /vendorGallery/{id} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /vendorPackages/{id} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    function isVendorOwner(vendorId) {
      return isSignedIn() && get(/databases/$(database)/documents/vendors/$(vendorId)).data.ownerUid == request.auth.uid;
    }
  }
}
