rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }
    function isUserAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"; }
    function isApprovedVendor() { return isSignedIn() && exists(/databases/$(database)/documents/vendors/$(request.auth.uid)) && get(/databases/$(database)/documents/vendors/$(request.auth.uid)).data.status == "approved"; }

    match /users/{id} {
      allow read: if isOwner(id) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == id && request.resource.data.role == "user";
      allow update: if (isOwner(id) && request.resource.data.role == resource.data.role) || isUserAdmin() || isAdmin();
      allow delete: if isUserAdmin() || isAdmin();
    }
    match /profiles/{id} {
      allow read: if resource.data.status == "approved" || isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
    }
    match /payments/{id} {
      allow read: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.status == "pending";
      allow update: if isUserAdmin() || isAdmin();
      allow delete: if isAdmin();
    }
    match /subscriptions/{id} {
      allow read: if isOwner(resource.data.uid) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(resource.data.uid) || isUserAdmin() || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
    match /interests/{id} {
      allow read: if isOwner(resource.data.fromUserId) || isOwner(resource.data.toUserId) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid && request.resource.data.status == "pending";
      allow update: if isOwner(resource.data.toUserId) || isUserAdmin() || isAdmin();
      allow delete: if isOwner(resource.data.fromUserId) || isUserAdmin() || isAdmin();
    }
    match /notifications/{id} {
      allow read: if isOwner(resource.data.userId) || (resource.data.target != null && (resource.data.target == "all" || (resource.data.target == "premium" && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.membershipTier != "free") || (resource.data.target == "free" && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.membershipTier == "free") || (resource.data.target == "vendors" && exists(/databases/$(database)/documents/vendors/$(request.auth.uid))))) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isUserAdmin() || isAdmin() || isOwner(resource.data.userId);
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if isUserAdmin() || isAdmin();
    }
    match /auditLog/{id} {
      allow read: if isUserAdmin() || isAdmin();
      allow create: if isUserAdmin() || isAdmin();
      allow update, delete: if isAdmin();
    }
    match /favourites/{id} {
      allow read: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
    }
    match /aiMatches/{id} {
      allow read: if isOwner(resource.data.uid) || isUserAdmin() || isAdmin();
      allow create: if isOwner(resource.data.uid);
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
    match /matchHistory/{id} {
      allow read: if isOwner(resource.data.uid) || isUserAdmin() || isAdmin();
      allow create: if isOwner(resource.data.uid);
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
    match /profileViews/{id} {
      allow read: if isOwner(resource.data.viewerUid) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /recentlyViewed/{id} {
      allow read: if isOwner(resource.data.uid) || isUserAdmin() || isAdmin();
      allow create: if isOwner(resource.data.uid);
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
    match /searchHistory/{id} {
      allow read: if isOwner(resource.data.uid) || isUserAdmin() || isAdmin();
      allow create: if isOwner(resource.data.uid);
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
    match /vendors/{id} {
      allow read: if resource.data.status == "approved" || isOwner(resource.data.ownerUid) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid) || isUserAdmin() || isAdmin();
      allow delete: if isUserAdmin() || isAdmin();
    }
    match /vendorCategories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /vendorBookings/{id} {
      allow read: if isOwner(resource.data.userId) || (isSignedIn() && exists(/databases/$(database)/documents/vendors/$(resource.data.vendorId)) && get(/databases/$(database)/documents/vendors/$(resource.data.vendorId)).data.ownerUid == request.auth.uid) || isUserAdmin() || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
    }
    match /vendorReviews/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isUserAdmin() || isAdmin();
    }
    match /vendorGallery/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.vendorId != null && exists(/databases/$(database)/documents/vendors/$(request.resource.data.vendorId)) && get(/databases/$(database)/documents/vendors/$(request.resource.data.vendorId)).data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/vendors/$(resource.data.vendorId)) && get(/databases/$(database)/documents/vendors/$(resource.data.vendorId)).data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/vendors/$(resource.data.vendorId)) && get(/databases/$(database)/documents/vendors/$(resource.data.vendorId)).data.ownerUid == request.auth.uid || isUserAdmin() || isAdmin();
    }
    match /vendorPackages/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.vendorId != null && exists(/databases/$(database)/documents/vendors/$(request.resource.data.vendorId)) && get(/databases/$(database)/documents/vendors/$(request.resource.data.vendorId)).data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/vendors/$(resource.data.vendorId)) && get(/databases/$(database)/documents/vendors/$(resource.data.vendorId)).data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/vendors/$(resource.data.vendorId)) && get(/databases/$(database)/documents/vendors/$(resource.data.vendorId)).data.ownerUid == request.auth.uid || isUserAdmin() || isAdmin();
    }
  }
}
